# DeepInfra API key — used for both document assessment and hint page generation
DEEPINFRA_API_KEY=your_deepinfra_api_key_here

# PayPal CosmosAI key — only required on the corporate network
COSMOS_API_KEY=your_cosmos_api_key_here

# App password — checked server-side only, never sent to the browser
APP_PASSWORD=your_password_here
